EXPO_PUBLIC_GEMINI_API_KEY=your_key_here

# App
EXPO_PUBLIC_APP_ENV=local
EXPO_PUBLIC_APP_SCHEME=did
EXPO_PUBLIC_OID4VCI_REDIRECT_URI=did://oid4vci
EXPO_PUBLIC_OID4VP_REDIRECT_URI=did://oid4vp
EXPO_PUBLIC_LOCALHOST_ALIAS=localhost

# Issuer
EXPO_PUBLIC_ISSUER_BASE_URL=http://localhost:8082/pid-issuer
EXPO_PUBLIC_ISSUER_OFFER_CREATE_URL=http://localhost:8082/pid-issuer/issuer/credentialsOffer/create
EXPO_PUBLIC_ISSUER_AUTHORIZATION_SERVER_BASE_URL=http://localhost:8082/idp
EXPO_PUBLIC_ISSUER_CLIENT_ID=wallet-dev
EXPO_PUBLIC_ISSUER_ENTRY_MODE=test-issuer
EXPO_PUBLIC_ISSUER_AUTH_MODE=authorization_code

# Verifier
EXPO_PUBLIC_VERIFIER_BASE_URL=http://localhost:8080
EXPO_PUBLIC_VERIFIER_INIT_TRANSACTION_URL=http://localhost:8080/ui/presentations
EXPO_PUBLIC_VERIFIER_REQUEST_SCHEME=openid4vp
EXPO_PUBLIC_VERIFIER_RESPONSE_MODE=direct_post
EXPO_PUBLIC_VERIFIER_JAR_MODE=by_reference

# Credential defaults
EXPO_PUBLIC_DEFAULT_TEST_CREDENTIAL=ehic_sd_jwt_vc
EXPO_PUBLIC_EHIC_ENABLED=true
EXPO_PUBLIC_EHIC_CREDENTIAL_CONFIGURATION_ID=urn:eudi:ehic:1:dc+sd-jwt-compact
EXPO_PUBLIC_EHIC_SCOPE=urn:eudi:ehic:1:dc+sd-jwt
EXPO_PUBLIC_EHIC_VCT=urn:eudi:ehic:1

EXPO_PUBLIC_PID_ENABLED=true
EXPO_PUBLIC_PID_CREDENTIAL_CONFIGURATION_ID=eu.europa.ec.eudi.pid_vc_sd_jwt
EXPO_PUBLIC_PID_SCOPE=eu.europa.ec.eudi.pid_vc_sd_jwt
EXPO_PUBLIC_PID_VCT=urn:eudi:pid:1

# Debug flags
EXPO_PUBLIC_ALLOW_SELF_SIGNED_CERT=true
EXPO_PUBLIC_ENABLE_TEST_ISSUER_MENU=true
EXPO_PUBLIC_ENABLE_SCAN_OFFER=true
EXPO_PUBLIC_ENABLE_PASTE_OFFER=true
EXPO_PUBLIC_ENABLE_VERIFIER_DEBUG_RESULT=true
